#!/usr/bin/env bash
set -euo pipefail

echo "=== Pre-commit: secret scan ==="

BLOCKED_PATTERNS=(
    '\.env$'
    '\.env\.'
    '\.secrets/'
    '\.token$'
    '\.key$'
    '\.pem$'
    '\.cookie'
    'state\.json'
)

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# Files matching a blocked pattern but explicitly safe to commit.
# .env.example is the canonical template file — never contains real secrets.
ALLOWLIST=(
    '\.env\.example$'
)

for file in $STAGED; do
    skip=0
    for allow in "${ALLOWLIST[@]}"; do
        if echo "$file" | grep -qE "$allow"; then
            skip=1
            break
        fi
    done
    [[ $skip -eq 1 ]] && continue

    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        if echo "$file" | grep -qE "$pattern"; then
            echo "BLOCKED: $file matches blocked pattern '$pattern'"
            exit 1
        fi
    done
done

_SECRET_CORE='\b(api_key|secret_key|password|token|sessionid)\s*[=:]\s*'
if git diff --cached -U0 | grep -iE "${_SECRET_CORE}[\"'][A-Za-z0-9+/=_.-]{8,}" >/dev/null 2>&1; then
    echo "BLOCKED: staged diff contains potential secret"
    exit 1
fi

_TDD_GATE='enabled'
if [[ "${TDD_BYPASS:-0}" != "1" ]]; then
    NON_TEST_CHANGES=$(echo "$STAGED" | grep -E -v '(^tests/|^__tests__/|(^|/).*\.(test|spec)\.[a-zA-Z0-9]+$|(^|/)test_.*\.[a-zA-Z0-9]+$|_test\.[a-zA-Z0-9]+$|\.md$|^docs/|^\.github/|^\.githooks/|^AGENTS\.md$|^CLAUDE\.md$|^decisions\.md$|^llms\.txt$)' || true)
    TEST_CHANGES=$(echo "$STAGED" | grep -E '(^tests/|^__tests__/|(^|/).*\.(test|spec)\.[a-zA-Z0-9]+$|(^|/)test_.*\.[a-zA-Z0-9]+$|_test\.[a-zA-Z0-9]+$)' || true)
    if [[ -n "$NON_TEST_CHANGES" && -z "$TEST_CHANGES" ]]; then
        echo "BLOCKED: TDD gate failed — code changes require test changes in the same commit."
        echo "Set TDD_BYPASS=1 only for emergency non-functional commits."
        exit 1
    fi
fi

echo "=== Pre-commit: passed ==="
