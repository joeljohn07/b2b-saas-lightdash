# Copy to `.env` and fill in values. Never commit `.env` itself (already gitignored).
#
# Required for local docker-compose. Production deployment may pass these via
# the orchestrator (systemd, k8s, etc.) rather than a .env file.

# -----------------------------------------------------------------------------
# Lightdash core
# -----------------------------------------------------------------------------

# Random secret used for session token signing. Generate with:
#   openssl rand -hex 32
LIGHTDASH_SECRET=replace-with-random-64-char-hex-string

# Log verbosity: debug | info | warn | error
LIGHTDASH_LOG_LEVEL=info

# Public URL where Lightdash will be reachable. For local dev keep the default;
# for VPS deployment set to the public domain (e.g., https://lightdash.example.com).
SITE_URL=http://localhost:8080

# Host port for the Lightdash UI (container always listens on 8080).
LIGHTDASH_PORT=8080

# -----------------------------------------------------------------------------
# Postgres metadata DB (Lightdash's own state — NOT the data warehouse)
# -----------------------------------------------------------------------------

PGUSER=lightdash
PGPASSWORD=replace-with-strong-password
PGDATABASE=lightdash

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage for BigQuery result pagination)
# -----------------------------------------------------------------------------
#
# Lightdash 0.2914+ requires S3-compatible storage to render BigQuery query
# results. The compose stack ships a local MinIO container; these credentials
# control access to it. For local dev, default values work; the lightdash-stack.sh
# launcher reads real values from macOS Keychain.

MINIO_ACCESS_KEY=lightdash-results-rw
MINIO_SECRET_KEY=replace-with-random-32-char-string

# Host ports for MinIO API and admin console (defaults: 9000, 9001).
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# BigQuery warehouse connection
# -----------------------------------------------------------------------------
#
# Not configured here. After `docker-compose up`, open http://localhost:8080
# and create a project; the Lightdash UI will ask for the warehouse
# connection. For local dev with mounted ADC credentials, choose
# "BigQuery > Application Default Credentials". For production, paste a
# service-account JSON key.
#
# Required project fields in the UI:
#   - GCP project ID:  (your project)
#   - Location:        EU (matches the dbt project default)
#   - dbt project dir: /usr/app/dbt
#   - Target:          dev
